{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": false,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "jsx": "react-jsx",
    "outDir": "dist",
    "rootDir": "src",
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "bun:bundle": ["src/stubs/bun-bundle.ts"],
      "src/*": ["src/*"]
    },
    "types": ["node"],
    "lib": ["ES2023", "DOM"],
    "allowImportingTsExtensions": false,
    "noEmit": false
  },
  "include": [
    "src/**/*",
    "src/stubs/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
